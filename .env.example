# Copy to .env.local (never commit .env.local — it's already gitignored).

# --- Claude API (required once you run real agents, e.g. packages/agents) ---
ANTHROPIC_API_KEY=

# --- Supabase (NOT connected yet — Phase 0 ships without this) ---
# Fill these in when you're ready to activate db/schema.sql. Until then,
# packages/agents/src/db.ts throws a clear error instead of silently no-op-ing.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
