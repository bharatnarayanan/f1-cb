# Environment variable template for the Trading Intelligence Platform.
# Copy to .env and fill in real values — .env is gitignored, never commit it.

# Which environment this is running in (development/production).
ENVIRONMENT=development

# Secret used to sign JWTs for login sessions. Generate with: openssl rand -hex 32
SECRET_KEY=changeme-generate-a-random-64-char-hex-string

# Connection string for the TimescaleDB (Postgres) database.
DATABASE_URL=postgresql+psycopg://tip:tip@localhost:5432/tip

# Connection string for Redis (live tick cache, rate limiting, alert dedup).
REDIS_URL=redis://localhost:6379/0

# Market data source: "sample" (default — in-memory mock data, no Zerodha login needed) or "live" (real Zerodha Kite Connect, requires the three KITE_* values below and a daily login via scripts/kite_daily_login.py).
DATA_MODE=sample

# Zerodha Kite Connect app key. Must be registered with READ-ONLY market-data scope only — never order-management scope. Only needed when DATA_MODE=live.
KITE_API_KEY=your-kite-api-key-here

# Daily Zerodha Kite Connect access token (read-only scope). Regenerate per Zerodha's token lifecycle.
KITE_ACCESS_TOKEN=your-kite-access-token-here

# Zerodha Kite Connect app secret. Used only locally to exchange a daily request_token for an access_token — never used for order placement, never sent to any other service.
KITE_API_SECRET=your-kite-api-secret-here

# Telegram bot token used to send recommendation alerts to you. Optional.
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Telegram chat id to send alerts to (message @userinfobot on Telegram to find yours). Optional.
TELEGRAM_CHAT_ID=your-telegram-chat-id-here

# Anthropic (Claude) API key, used only to narrate the reasoning tree and extract Strategy Marketplace logic — never for numeric decisions. Optional.
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# SMTP server hostname for optional email alerts. Optional.
SMTP_HOST=smtp.example.com

# SMTP server port for optional email alerts. Optional.
SMTP_PORT=587

# SMTP account username for sending email alerts. Optional.
SMTP_USER=your-smtp-username-here

# SMTP account password for sending email alerts. Optional.
SMTP_PASSWORD=your-smtp-password-here

# Email address to send recommendation alerts to. Optional.
ALERT_EMAIL_TO=your-email@example.com
